{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-bridge/runtime-manifest.schema.json",
  "title": "codex-bridge runtime manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "runtimeId",
    "runtimeVersion",
    "platform",
    "patchSchemaVersion",
    "upstreamRelease",
    "desktopWebview",
    "appServer"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "runtimeId": {
      "type": "string",
      "minLength": 1
    },
    "runtimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "patchSchemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "upstreamRelease": {
      "type": "object",
      "required": [
        "repo",
        "tag"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "desktopWebview": {
      "type": "object",
      "required": [
        "source",
        "version",
        "asset",
        "path",
        "sha256"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "appServer": {
      "type": "object",
      "required": [
        "source",
        "version",
        "asset",
        "path",
        "sha256"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

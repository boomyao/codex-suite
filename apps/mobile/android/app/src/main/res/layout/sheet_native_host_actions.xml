<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_native_host_sheet_surface"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="42dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_native_host_sheet_handle" />

        <TextView
            android:id="@+id/nativeHostSheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/nativeHostTextPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nativeHostSheetBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/nativeHostTextSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/nativeHostSheetMetadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_native_host_subtle"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/nativeHostSheetMetadataTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/nativeHostTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nativeHostSheetMetadataValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:textColor="@color/nativeHostTextPrimary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nativeHostSheetConnectionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/nativeHostSheetConnectionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/native_host_sheet_saved_connections"
                android:textColor="@color/nativeHostTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/nativeHostSheetConnectionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nativeHostSheetPrimaryAction"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textAllCaps="false"
            app:backgroundTint="@color/nativeHostAccent"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nativeHostSheetSecondaryAction"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAllCaps="false"
            android:textColor="@color/nativeHostTextPrimary"
            app:cornerRadius="22dp"
            app:strokeColor="@color/nativeHostDivider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nativeHostSheetTertiaryAction"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAllCaps="false"
            android:textColor="@color/nativeHostWarning" />

    </LinearLayout>
</ScrollView>

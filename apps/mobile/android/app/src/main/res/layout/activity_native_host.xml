<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_native_host_window">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/nativeHostToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            app:subtitle="@string/native_host_subtitle_default"
            app:subtitleTextColor="@color/nativeHostTextSecondary"
            app:title="@string/native_host_title"
            app:titleTextColor="@color/nativeHostTextPrimary" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/nativeHostProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/nativeHostAccent"
            app:trackColor="@color/nativeHostAccentMuted" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/nativeHostHeroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/nativeHostSurface"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/nativeHostDivider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_native_host_hero_header"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_native_host_badge"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_native_host_badge_dot" />

                        <TextView
                            android:id="@+id/nativeHostHeroEyebrow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/native_host_hero_eyebrow_idle"
                            android:textColor="@color/nativeHostHeroBadgeText"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/nativeHostStateChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_native_host_state_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/native_host_state_ready"
                        android:textColor="@color/nativeHostChipNeutralText"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="20dp">

                    <ImageView
                        android:id="@+id/nativeHostStateIcon"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:contentDescription="@string/app_name"
                        android:src="@drawable/splashscreen_logo" />

                    <TextView
                        android:id="@+id/nativeHostEmptyTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/native_host_empty_title"
                        android:textColor="@color/nativeHostTextPrimary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/nativeHostEmptyBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/native_host_empty_body"
                        android:textColor="@color/nativeHostTextSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/nativeHostStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/native_host_status_idle"
                        android:textColor="@color/nativeHostTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/nativeHostRuntimeDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_native_host_subtle"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/nativeHostRuntimeLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/native_host_runtime_label_endpoint"
                            android:textColor="@color/nativeHostTextSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nativeHostRuntimeValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/nativeHostTextPrimary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/nativeHostHintCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_native_host_subtle"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/nativeHostHintTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/native_host_hint_idle_title"
                            android:textColor="@color/nativeHostTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nativeHostHintBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/native_host_hint_idle_body"
                            android:textColor="@color/nativeHostTextSecondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nativeHostPrimaryAction"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/native_host_empty_action"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/nativeHostAccent"
                            app:cornerRadius="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nativeHostSecondaryAction"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="@string/native_host_secondary_action_manage"
                            android:textAllCaps="false"
                            android:textColor="@color/nativeHostTextPrimary"
                            app:cornerRadius="22dp"
                            app:strokeColor="@color/nativeHostDividerStrong" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/nativeHostWorkspaceFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="90dp"
            android:layout_weight="1"
            android:background="@drawable/bg_native_host_surface"
            android:clipToOutline="true"
            android:elevation="6dp"
            android:outlineProvider="background">

            <WebView
                android:id="@+id/nativeHostWebView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/nativeHostWebSurface"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/nativeHostEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_native_host_workspace_placeholder"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_native_host_state_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/native_host_workspace_preview_eyebrow"
                    android:textColor="@color/nativeHostChipActiveText"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_marginTop="18dp"
                    android:alpha="0.92"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/splashscreen_logo" />

                <TextView
                    android:id="@+id/nativeHostWorkspaceEmptyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="@string/native_host_workspace_preview_title"
                    android:textColor="@color/nativeHostTextPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nativeHostWorkspaceEmptyBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/native_host_workspace_preview_body"
                    android:textColor="@color/nativeHostTextSecondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/nativeHostConnectionButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="22dp"
        android:minWidth="0dp"
        android:text="@string/native_host_fab_connect"
        android:textAllCaps="false"
        android:textColor="@color/nativeHostTextPrimary"
        app:backgroundTint="@color/nativeHostSurface"
        app:cornerRadius="24dp"
        app:rippleColor="@color/nativeHostAccentMuted"
        app:strokeColor="@color/nativeHostDivider"
        app:strokeWidth="1dp" />

</FrameLayout>

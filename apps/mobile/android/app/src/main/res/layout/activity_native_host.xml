<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nativeHostRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nativeHostBackground"
    tools:ignore="UselessParent">

    <WebView
        android:id="@+id/nativeHostWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/nativeHostWebSurface"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/nativeHostDisconnectedContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nativeHostSettingsButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                app:icon="@drawable/ic_native_host_settings"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/nativeHostTextSecondary" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/nativeHostCenterContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/nativeHostErrorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/nativeHostSurface"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/nativeHostDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:id="@+id/nativeHostErrorTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/nativeHostTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Couldn't open workspace" />

                    <TextView
                        android:id="@+id/nativeHostErrorBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/nativeHostTextSecondary"
                        android:textSize="13sp"
                        tools:text="Retry, choose another saved session, or scan a fresh desktop QR code." />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nativeHostErrorPrimaryAction"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/nativeHostAccent"
                            app:cornerRadius="20dp"
                            tools:text="Retry" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nativeHostErrorSecondaryAction"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:minWidth="0dp"
                            android:text="@string/native_host_secondary_action_manage"
                            android:textAllCaps="false"
                            android:textColor="@color/nativeHostTextSecondary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/nativeHostBrandTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/native_host_brand_title"
                android:textColor="@color/nativeHostTextPrimary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nativeHostPrimaryScanButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:minHeight="52dp"
                android:text="@string/native_host_empty_action_full"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/nativeHostTextPrimary"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_native_host_scan"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/nativeHostSavedSessionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nativeHostSavedSessionsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/native_host_saved_sessions_title"
                    android:textAllCaps="true"
                    android:textColor="@color/nativeHostTextSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nativeHostSavedSessionsAction"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:text="@string/native_host_saved_sessions_action"
                    android:textAllCaps="false"
                    android:textColor="@color/nativeHostTextSecondary"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeHostRecentSessionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nativeHostLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/nativeHostBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorColor="@color/nativeHostTextPrimary" />

        <TextView
            android:id="@+id/nativeHostLoadingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/nativeHostTextSecondary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Opening your workspace" />

        <TextView
            android:id="@+id/nativeHostLoadingProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/nativeHostTextSecondary"
            android:textSize="12sp"
            tools:text="desktop" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nativeHostReconnectOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/nativeHostBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/native_host_reconnect_title"
            android:textColor="@color/nativeHostTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nativeHostReconnectStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/nativeHostTextSecondary"
            android:textSize="13sp"
            tools:text="Lost contact with the desktop bridge." />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:indicatorColor="@color/nativeHostTextPrimary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nativeHostReconnectPrimaryAction"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/native_host_retry_now_action"
                android:textAllCaps="false"
                app:backgroundTint="@color/nativeHostTextPrimary"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nativeHostReconnectSecondaryAction"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:text="@string/native_host_secondary_action_manage"
                android:textAllCaps="false"
                android:textColor="@color/nativeHostTextSecondary" />
        </LinearLayout>
    </LinearLayout>


</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/nativeHostWindowEnd"
                android:startColor="@color/nativeHostWindowStart" />
        </shape>
    </item>
    <item
        android:gravity="top|end"
        android:right="-48dp"
        android:top="-72dp">
        <shape android:shape="oval">
            <size
                android:width="240dp"
                android:height="240dp" />
            <gradient
                android:centerColor="@color/nativeHostWindowSpotlight"
                android:endColor="@android:color/transparent"
                android:gradientRadius="140dp"
                android:startColor="@color/nativeHostWindowSpotlight"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
